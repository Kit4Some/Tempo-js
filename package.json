{
  "name": "tempo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Tempo — a 353-parameter online-learning MLP that predicts browser frame budget overruns. Research artifact.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "bench:part1": "node scripts/benchmark.js --mode=part1 --reps=10",
    "bench:part2": "node scripts/benchmark.js --mode=part2 --reps=10",
    "bench:compare": "node scripts/analyze.js --compare=docs/PHASE5_PART1_RESULTS.jsonl,docs/PHASE5_PART2_RESULTS.jsonl",
    "bench:drift": "node scripts/drift-check.js --part1=docs/PHASE5_PART1_RESULTS.jsonl --part2=docs/PHASE5_PART2_RESULTS.jsonl"
  },
  "devDependencies": {
    "puppeteer": "^23.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
